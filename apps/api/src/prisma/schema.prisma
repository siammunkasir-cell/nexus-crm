generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"]
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, uuid_ossp]
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
  CLIENT
}

enum PlanType {
  FREE
  PRO
  AGENCY
  ENTERPRISE
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
}

enum ActivityType {
  CALL
  EMAIL
  SMS
  MEETING
  TASK
  NOTE
  AI_INTERACTION
}

enum CampaignType {
  EMAIL
  SMS
  SOCIAL
  SEQUENCE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
}

enum ConversationChannel {
  CHAT
  EMAIL
  SMS
  WHATSAPP
  INSTAGRAM
}

enum ConversationStatus {
  OPEN
  RESOLVED
  AI_HANDLED
}

enum MessageSender {
  USER
  CONTACT
  AI
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ProductType {
  ONE_TIME
  RECURRING
}

// ─────────── 1. USER ───────────
model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  name            String?
  avatar          String?
  role            UserRole  @default(MEMBER)
  hashedPassword  String?  @map("hashed_password")
  emailVerified   DateTime?
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)

  organizationId  String?   @map("organization_id") @db.Uuid
  organization    Organization? @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: Cascade)

  ownedOrganization Organization[] @relation("OrganizationOwner")

  contacts        Contact[]
  assignedDeals   Deal[]
  activities      Activity[]
  conversations   Conversation[]
  aiConversations AIConversation[]
  notifications   Notification[]
  apiKeys         ApiKey[]
  auditLogs       AuditLog[]
  sessions        Session[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

// ─────────── 2. ORGANIZATION ───────────
model Organization {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  slug               String   @unique
  logo               String?
  plan               PlanType @default(FREE)
  customDomain       String?
  settings           Json     @default("{}")
  aiPersonaName      String   @default("Nexus")
  aiSystemPrompt     String?
  stripeCustomerId   String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")

  ownerId            String   @map("owner_id") @db.Uuid
  owner              User     @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  users              User[]   @relation("OrganizationUsers")
  contacts           Contact[]
  pipelines          Pipeline[]
  deals              Deal[]
  activities         Activity[]
  campaigns          Campaign[]
  automations        Automation[]
  forms              Form[]
  formSubmissions    FormSubmission[]
  pages              Page[]
  funnels            Funnel[]
  conversations      Conversation[]
  messages           Message[]
  aiConversations    AIConversation[]
  invoices           Invoice[]
  products           Product[]
  websiteVisitors    WebsiteVisitor[]
  trafficSources     TrafficSource[]
  apiKeys            ApiKey[]
  webhooks           Webhook[]
  auditLogs          AuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([plan])
  @@map("organizations")
}

// ─────────── 3. CONTACT ───────────
model Contact {
  id             String        @id @default(uuid()) @db.Uuid
  firstName      String        @map("first_name")
  lastName       String?       @map("last_name")
  email          String?
  phone          String?
  avatar         String?
  tags           String[]      @default([])
  source         String?
  status         ContactStatus @default(LEAD)
  customFields   Json          @default("{}") @map("custom_fields")
  notes          String?
  score          Int           @default(0)

  organizationId String        @map("organization_id") @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedToId   String?       @map("assigned_to_id") @db.Uuid
  assignedTo     User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  deals          Deal[]
  activities     Activity[]
  conversations  Conversation[]
  aiConversations AIConversation[]
  invoices       Invoice[]
  formSubmissions FormSubmission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@index([assignedToId])
  @@index([score])
  @@map("contacts")
}

// ─────────── 4. PIPELINE ───────────
model Pipeline {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  stages         Json     @default("[]")
  isDefault      Boolean  @default(false) @map("is_default")

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  deals          Deal[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([isDefault])
  @@map("pipelines")
}

// ─────────── 5. DEAL ───────────
model Deal {
  id                String   @id @default(uuid()) @db.Uuid
  title             String
  value             Float    @default(0)
  currency          String   @default("USD")
  probability       Int      @default(0)
  expectedCloseDate DateTime? @map("expected_close_date")
  stageId           String   @map("stage_id")
  lostReason        String?  @map("lost_reason")
  wonAt             DateTime? @map("won_at")
  lostAt            DateTime? @map("lost_at")

  pipelineId        String   @map("pipeline_id") @db.Uuid
  pipeline          Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Restrict)

  contactId         String?  @map("contact_id") @db.Uuid
  contact           Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  organizationId    String   @map("organization_id") @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedToId      String?  @map("assigned_to_id") @db.Uuid
  assignedTo        User?    @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  activities        Activity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([probability])
  @@index([value])
  @@map("deals")
}

// ─────────── 6. ACTIVITY ───────────
model Activity {
  id            String       @id @default(uuid()) @db.Uuid
  type          ActivityType
  title         String
  body          String?
  scheduledAt   DateTime?    @map("scheduled_at")
  completedAt   DateTime?    @map("completed_at")
  duration      Int?
  metadata      Json         @default("{}")

  contactId     String?      @map("contact_id") @db.Uuid
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  dealId        String?      @map("deal_id") @db.Uuid
  deal          Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)

  userId        String       @map("user_id") @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String      @map("organization_id") @db.Uuid
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([dealId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

// ─────────── 7. CAMPAIGN ───────────
model Campaign {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  subject        String?
  body           String?
  templateId     String?        @map("template_id")
  audienceFilter Json           @default("{}") @map("audience_filter")
  scheduledAt    DateTime?      @map("scheduled_at")
  sentAt         DateTime?      @map("sent_at")
  stats          Json           @default("{}")

  organizationId String         @map("organization_id") @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([status])
  @@index([type])
  @@map("campaigns")
}

// ─────────── 8. AUTOMATION ───────────
model Automation {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  trigger        Json
  steps          Json
  isActive       Boolean  @default(false) @map("is_active")
  runCount       Int      @default(0) @map("run_count")
  lastRunAt      DateTime? @map("last_run_at")

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([isActive])
  @@map("automations")
}

// ─────────── 9. FORM ───────────
model Form {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  slug           String
  fields         Json
  settings       Json     @default("{}")
  embedCode      String?  @map("embed_code")
  submissions    Int      @default(0)
  isPublished    Boolean  @default(false) @map("is_published")

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  pageId         String?  @map("page_id") @db.Uuid
  page           Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  formSubmissions FormSubmission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([slug])
  @@map("forms")
}

// ─────────── 10. FORM SUBMISSION ───────────
model FormSubmission {
  id             String   @id @default(uuid()) @db.Uuid
  data           Json
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  source         String?

  formId         String   @map("form_id") @db.Uuid
  form           Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  contactId      String?  @map("contact_id") @db.Uuid
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([formId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("form_submissions")
}

// ─────────── 11. PAGE (Landing / Funnel Step) ───────────
model Page {
  id             String   @id @default(uuid()) @db.Uuid
  title          String
  slug           String
  content        Json     @default("{}")
  metaTitle      String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  publishedAt    DateTime? @map("published_at")
  isPublished    Boolean  @default(false) @map("is_published")
  visits         Int      @default(0)
  conversions    Int      @default(0)

  funnelId       String?  @map("funnel_id") @db.Uuid
  funnel         Funnel?  @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  forms          Form[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([slug])
  @@index([funnelId])
  @@map("pages")
}

// ─────────── 12. FUNNEL ───────────
model Funnel {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  totalVisits      Int      @default(0) @map("total_visits")
  totalConversions Int      @default(0) @map("total_conversions")
  revenue          Float    @default(0)

  organizationId   String   @map("organization_id") @db.Uuid
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  pages            Page[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("funnels")
}

// ─────────── 13. CONVERSATION ───────────
model Conversation {
  id             String              @id @default(uuid()) @db.Uuid
  channel        ConversationChannel
  status         ConversationStatus  @default(OPEN)

  contactId      String?             @map("contact_id") @db.Uuid
  contact        Contact?            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  organizationId String              @map("organization_id") @db.Uuid
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedToId   String?             @map("assigned_to_id") @db.Uuid
  assignedTo     User?               @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  lastMessageAt  DateTime?           @map("last_message_at")
  messages       Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([status])
  @@index([channel])
  @@map("conversations")
}

// ─────────── 14. MESSAGE ───────────
model Message {
  id             String         @id @default(uuid()) @db.Uuid
  body           String
  type           String         @default("TEXT")
  sender         MessageSender
  metadata       Json           @default("{}")
  isRead         Boolean        @default(false) @map("is_read")

  conversationId String         @map("conversation_id") @db.Uuid
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  organizationId String         @map("organization_id") @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  sentAt  DateTime @default(now()) @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([organizationId])
  @@index([sender])
  @@map("messages")
}

// ─────────── 15. AI CONVERSATION ───────────
model AIConversation {
  id             String   @id @default(uuid()) @db.Uuid
  messages       Json     @default("[]")
  context        Json     @default("{}")
  tokensUsed     Int      @default(0) @map("tokens_used")

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  contactId      String?  @map("contact_id") @db.Uuid
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("ai_conversations")
}

// ─────────── 16. INVOICE ───────────
model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  number         String        @unique
  status         InvoiceStatus @default(DRAFT)
  lineItems      Json          @default("[]") @map("line_items")
  subtotal       Float         @default(0)
  tax            Float         @default(0)
  total          Float         @default(0)
  currency       String        @default("USD")
  dueDate        DateTime?     @map("due_date")
  paidAt         DateTime?     @map("paid_at")

  contactId      String?       @map("contact_id") @db.Uuid
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  organizationId String        @map("organization_id") @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([status])
  @@index([number])
  @@map("invoices")
}

// ─────────── 17. PRODUCT / SERVICE ───────────
model Product {
  id             String      @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  price          Float       @default(0)
  currency       String      @default("USD")
  type           ProductType @default(ONE_TIME)
  stripePriceId  String?     @map("stripe_price_id")

  organizationId String      @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([type])
  @@map("products")
}

// ─────────── 18. WEBSITE VISITOR ───────────
model WebsiteVisitor {
  id             String   @id @default(uuid()) @db.Uuid
  sessionId      String   @map("session_id")
  pageUrl        String   @map("page_url")
  referrer       String?
  userAgent      String?  @map("user_agent")
  ipAddress      String?  @map("ip_address")
  country        String?
  city           String?
  device         String?
  entryAt        DateTime @map("entry_at")
  exitAt         DateTime? @map("exit_at")
  duration       Int?
  events         Json     @default("[]")

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([sessionId])
  @@index([entryAt])
  @@index([pageUrl])
  @@map("website_visitors")
}

// ─────────── 19. TRAFFIC SOURCE ───────────
model TrafficSource {
  id             String   @id @default(uuid()) @db.Uuid
  date           DateTime
  source         String
  medium         String?
  campaign       String?
  sessions       Int      @default(0)
  pageviews      Int      @default(0)
  bounceRate     Float    @default(0) @map("bounce_rate")
  avgDuration    Float    @default(0) @map("avg_duration")

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([source])
  @@index([date])
  @@map("traffic_sources")
}

// ─────────── 20. NOTIFICATION ───────────
model Notification {
  id             String   @id @default(uuid()) @db.Uuid
  type           String
  title          String
  body           String?
  isRead         Boolean  @default(false) @map("is_read")
  link           String?
  metadata       Json     @default("{}")

  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────── 21. API KEY ───────────
model ApiKey {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  key            String   @unique
  lastUsedAt     DateTime? @map("last_used_at")

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([key])
  @@map("api_keys")
}

// ─────────── 22. WEBHOOK ───────────
model Webhook {
  id               String   @id @default(uuid()) @db.Uuid
  url              String
  events           String[]
  secret           String?
  isActive         Boolean  @default(false) @map("is_active")
  deliveries       Int      @default(0)
  failedDeliveries Int      @default(0) @map("failed_deliveries")

  organizationId   String   @map("organization_id") @db.Uuid
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([isActive])
  @@map("webhooks")
}

// ─────────── 23. AUDIT LOG ───────────
model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  action         String
  resource       String
  resourceId     String?  @map("resource_id")
  oldValue       Json?    @map("old_value")
  newValue       Json?    @map("new_value")
  ipAddress      String?  @map("ip_address")

  userId         String?  @map("user_id") @db.Uuid
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  organizationId String   @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────── AUTH SESSION ───────────
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  refreshToken String?  @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  userAgent    String?
  ipAddress    String?  @map("ip_address")
  isRevoked    Boolean  @default(false) @map("is_revoked")

  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
  @@map("sessions")
}

// ─────────── VERIFICATION TOKEN ───────────
model VerificationToken {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  token      String   @unique
  expires    DateTime
  type       String   @default("EMAIL_VERIFY")

  @@index([identifier])
  @@index([expires])
  @@map("verification_tokens")
}
